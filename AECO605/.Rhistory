1530000, 204000,  16000, 19000, 590000, 102000, 1042000, 18006, 156000,
1705555, 182826,  17490, 14508, 671459, 112924, 1085991, 17779, 152847,
1634921, 148980,  11408, 19424, 814855, 109316,  803988, 16529, 139226,
1398884, 215323,  51600, 44016, 662671, 131693,  682130, 16995, 121685,
1519656, 342883,  32294, 59661, 463437, 463437,  933233, 19168, 102732,
1476928, 275367,  18008, 45798, 643942, 101799,  647930, 28921,  98912,
1563887, 245675,  17874, 22364, 616870, 143497,  687139, 20372, 101525,
1526425, 237647,  13444, 15242, 653953, 136183,  567875, 29717,  85911,
1601000, 223000,  11000, 32000, 603000, 139000,  746000, 23558,  55000,
1566082, 245554,   9224, 32689, 521823, 183550,  658821, 19955,  43905
), nrow = 22, ncol = 9, byrow = TRUE)
rownames(raw_data) <- year_labels
colnames(raw_data) <- crop_names
nYears <- nrow(raw_data)
n      <- ncol(raw_data)
nT     <- nYears - 1  # number of transitions
cat("Data: Andhra Pradesh Kharif Crop Area (hectares)\n")
cat("Years:", nYears, paste0("(", year_labels[1], " to ", year_labels[nYears], ")"), "\n")
cat("Crops:", n, "\n")
cat("Transitions:", nT, "\n\n")
# ===================== CONVERT TO PROPORTIONS =================================
S <- raw_data / rowSums(raw_data)
cat("Proportion matrix (first 5 years):\n")
print(round(S[1:5, ], 6))
cat("\nRow sums check:", all(abs(rowSums(S) - 1) < 1e-10), "\n\n")
# ===================== CONSTRUCT X AND Y ======================================
# X = proportions at time t   (rows 1 to T-1)
# Y = proportions at time t+1 (rows 2 to T)
# Model: Y ≈ X %*% P
Xmat <- S[1:nT, ]
Ymat <- S[2:nYears, ]
# Precompute common matrices
Q <- t(Xmat) %*% Xmat   # X'X  (n x n)
C <- t(Xmat) %*% Ymat   # X'Y  (n x n)
# ===================== SIMPLEX PROJECTION =====================================
# Wang & Carreira-Perpigñán algorithm
# Projects a vector onto the probability simplex {x : sum(x)=1, x>=0}
project_simplex <- function(v) {
n <- length(v)
u <- sort(v, decreasing = TRUE)
cum_sum <- cumsum(u)
rho <- max(which(u + (1 - cum_sum) / (1:n) > 0))
lambda <- (1 - cum_sum[rho]) / rho
pmax(v + lambda, 0)
}
# ===================== HELPER: Compute SSR ====================================
compute_SSR <- function(Xmat, Ymat, P) {
Residuals <- Ymat - Xmat %*% P
sum(Residuals^2)
}
# ===================== HELPER: Compute SAD ====================================
compute_SAD <- function(Xmat, Ymat, P) {
Residuals <- Ymat - Xmat %*% P
sum(abs(Residuals))
}
# =============================================================================
# METHOD 1: RESTRICTED LEAST SQUARES (Projected Gradient Descent)
#
# Book Ch.3: Min ||Y - XP||^2  s.t. sum_j(p_ij)=1, p_ij >= 0
#
# The objective is a quadratic in P: f(P) = 0.5 * ||Y - XP||^2
# Gradient: G = X'XP - X'Y = QP - C
# The row-sum and non-negativity constraints are enforced by projecting
# each row of P onto the probability simplex after each gradient step.
#
# Step size: eta = 1.9 / trace(Q), where trace(Q) approximates the
# largest eigenvalue of the Hessian, ensuring stable convergence.
# =============================================================================
solve_RLS <- function(Q, C, Xmat, Ymat, n, nT,
max_iter = 5000, tol = 1e-8) {
# Initialize: diagonal-heavy stochastic matrix
P <- matrix(0.2 / (n - 1), n, n)
diag(P) <- 0.8
# Learning rate from trace of Hessian
tr_Q <- sum(diag(Q))
if (tr_Q == 0) tr_Q <- 1
lr <- 1.9 / tr_Q
for (iter in 1:max_iter) {
# Gradient: G = QP - C
grad <- Q %*% P - C
# Gradient descent step + simplex projection (row by row)
P_new <- P - lr * grad
for (i in 1:n) {
P_new[i, ] <- project_simplex(P_new[i, ])
}
# Convergence check
max_diff <- max(abs(P_new - P))
P <- P_new
if (max_diff < tol) break
}
SSR <- compute_SSR(Xmat, Ymat, P)
list(P = P, SSR = SSR, iterations = iter)
}
# =============================================================================
# METHOD 2: MAXIMUM LIKELIHOOD / GLS (Iterative Weighted LS)
#
# Book Ch.6,8: The ML, GLS, and MCS estimators are mathematically identical.
#   p* = (X*' Sigma*^-1 X*)^-1  X*' Sigma*^-1 y*
#
# Under the multinomial/Lexis scheme:
#   Var(y_j(t)) = q_j(t) * (1 - q_j(t)) / N(t)
# where q_j(t) = predicted proportion = sum_k x_k(t) * p_kj
#
# GLS weight for equation j at time t:
#   w_j(t) = 1 / [q_j(t) * (1 - q_j(t))]
# (N(t) cancels in relative weighting)
#
# The iterative feedback procedure (Book §8.3):
#   1. Start from RLS solution
#   2. Compute predicted q_j(t) from current P
#   3. Form weight matrix from q_j(t)
#   4. Solve weighted LS via PGD with simplex projection
#   5. Repeat until convergence (book: 3-4 iterations typical)
#
# Weighted gradient:
#   G_w(i,j) = sum_t w_j(t) * x_i(t) * [sum_k x_k(t)*p_kj - y_j(t)]
# =============================================================================
solve_ML <- function(Xmat, Ymat, n, nT, P_init,
max_outer = 20, max_inner = 2000,
tol_outer = 1e-6, tol_inner = 1e-8,
eps = 1e-4) {
P <- P_init  # Warm start from RLS
for (outer in 1:max_outer) {
P_old <- P
# --- Compute predicted proportions q_j(t) = X %*% P ---
qPred <- Xmat %*% P
# Clamp to [eps, 1-eps] to avoid division by zero
# (Book amends zeros to 0.0001)
qPred <- pmax(pmin(qPred, 1 - eps), eps)
# --- Compute GLS weights: w_j(t) = 1/[q_j(t)*(1-q_j(t))] ---
# This is the inverse multinomial variance (up to common N(t))
W <- 1 / (qPred * (1 - qPred))  # (nT x n) matrix
# --- Estimate step size from weighted trace ---
# Approximate trace of X' diag(avg_w) X
avg_W_per_t <- rowMeans(W)  # average weight per time period
tr_Q <- 0
for (i in 1:n) {
tr_Q <- tr_Q + sum(avg_W_per_t * Xmat[, i]^2)
}
if (tr_Q == 0) tr_Q <- 1
lr <- 1.5 / tr_Q
# --- Inner PGD loop: solve weighted LS ---
for (inner in 1:max_inner) {
# Weighted residuals
Resid <- Xmat %*% P - Ymat  # (nT x n)
# Weighted gradient: G_w(i,j) = sum_t w_j(t)*x_i(t)*resid(t,j)
gradW <- t(Xmat) %*% (W * Resid)
# Gradient descent + simplex projection
P_new <- P - lr * gradW
for (i in 1:n) {
P_new[i, ] <- project_simplex(P_new[i, ])
}
max_diff_inner <- max(abs(P_new - P))
P <- P_new
if (max_diff_inner < tol_inner) break
}
# Outer convergence: weights have stabilized
max_diff_outer <- max(abs(P - P_old))
if (max_diff_outer < tol_outer) break
}
SSR <- compute_SSR(Xmat, Ymat, P)
list(P = P, SSR = SSR, outer_iterations = outer)
}
# =============================================================================
# METHOD 3: MINIMUM ABSOLUTE DEVIATIONS (IRLS Approximation)
#
# Book Ch.10: Min sum|y_j(t) - sum_k x_k(t)*p_kj|  s.t. Gp=1, p>=0
#
# The book solves via LP (simplex algorithm). Here we use IRLS which
# exploits: |u| = u^2/|u|, so Min sum|u_i| ~ Min sum (1/|u_i|)*u_i^2
#
# IRLS weights: w(t,j) = 1 / max(|residual(t,j)|, eps)
#   - Large residuals get SMALL weights (outlier downweighting)
#   - Small residuals get LARGE weights
#   - eps = 0.0001 floor prevents division by zero
#
# Each outer iteration recomputes weights from current residuals,
# then inner PGD solves the resulting weighted LS with simplex projection.
# =============================================================================
solve_MAD <- function(Q, C, Xmat, Ymat, n, nT, P_init,
max_outer = 30, max_inner = 2000,
tol_outer = 1e-6, tol_inner = 1e-8,
eps = 1e-4) {
P <- P_init  # Warm start from RLS
for (outer in 1:max_outer) {
P_old <- P
# --- Compute residuals and IRLS weights ---
Resid <- Ymat - Xmat %*% P
W <- 1 / pmax(abs(Resid), eps)  # (nT x n) IRLS weight matrix
# --- Estimate step size from weighted trace ---
avg_W_per_t <- rowMeans(W)
tr_Q <- 0
for (i in 1:n) {
tr_Q <- tr_Q + sum(avg_W_per_t * Xmat[, i]^2)
}
if (tr_Q == 0) tr_Q <- 1
lr <- 1.5 / tr_Q
# --- Inner PGD on weighted LS ---
for (inner in 1:max_inner) {
Resid_inner <- Xmat %*% P - Ymat
# Weighted gradient
gradW <- t(Xmat) %*% (W * Resid_inner)
# Gradient descent + simplex projection
P_new <- P - lr * gradW
for (i in 1:n) {
P_new[i, ] <- project_simplex(P_new[i, ])
}
max_diff_inner <- max(abs(P_new - P))
P <- P_new
if (max_diff_inner < tol_inner) break
}
# Outer convergence
max_diff_outer <- max(abs(P - P_old))
if (max_diff_outer < tol_outer) break
}
SAD <- compute_SAD(Xmat, Ymat, P)
list(P = P, SAD = SAD, outer_iterations = outer)
}
# =============================================================================
# RUN ALL THREE METHODS
# =============================================================================
cat("=============================================\n")
cat("  Running Method 1: Restricted Least Squares\n")
cat("=============================================\n")
res_RLS <- solve_RLS(Q, C, Xmat, Ymat, n, nT)
cat("  Converged in", res_RLS$iterations, "iterations\n")
cat("  SSR =", formatC(res_RLS$SSR, digits = 10, format = "f"), "\n\n")
cat("=============================================\n")
cat("  Running Method 2: ML / GLS\n")
cat("=============================================\n")
res_ML <- solve_ML(Xmat, Ymat, n, nT, res_RLS$P)
cat("  Outer iterations:", res_ML$outer_iterations, "\n")
cat("  SSR =", formatC(res_ML$SSR, digits = 10, format = "f"), "\n\n")
cat("=============================================\n")
cat("  Running Method 3: MAD (IRLS)\n")
cat("=============================================\n")
res_MAD <- solve_MAD(Q, C, Xmat, Ymat, n, nT, res_RLS$P)
cat("  Outer iterations:", res_MAD$outer_iterations, "\n")
cat("  SAD =", formatC(res_MAD$SAD, digits = 10, format = "f"), "\n\n")
# =============================================================================
# DISPLAY RESULTS
# =============================================================================
print_TPM <- function(P, crop_names, title, metric_name, metric_val, iter = NULL) {
cat(strrep("=", 70), "\n")
cat(title, "\n")
cat(strrep("-", 70), "\n")
# Named matrix
P_display <- P
rownames(P_display) <- crop_names
colnames(P_display) <- crop_names
cat("\nTransition Probability Matrix:\n\n")
print(round(P_display, 6))
cat("\nRow sums: ", paste(round(rowSums(P), 8), collapse = "  "), "\n")
cat(metric_name, ":", formatC(metric_val, digits = 10, format = "f"), "\n")
if (!is.null(iter)) cat("Iterations:", iter, "\n")
cat(strrep("=", 70), "\n\n")
}
print_TPM(res_RLS$P, crop_names,
"Method 1: Restricted Least Squares (RLS) - Book Ch.3",
"SSR", res_RLS$SSR, res_RLS$iterations)
print_TPM(res_ML$P, crop_names,
"Method 2: Maximum Likelihood / GLS (ML) - Book Ch.6,8",
"SSR", res_ML$SSR, res_ML$outer_iterations)
print_TPM(res_MAD$P, crop_names,
"Method 3: Minimum Absolute Deviations (MAD) - Book Ch.10",
"SAD", res_MAD$SAD, res_MAD$outer_iterations)
# =============================================================================
# COMPARISON TABLE
# =============================================================================
cat("\n")
cat(strrep("=", 60), "\n")
cat("  COMPARISON OF THREE METHODS\n")
cat(strrep("=", 60), "\n\n")
SSR_RLS <- res_RLS$SSR
SSR_ML  <- res_ML$SSR
SAD_MAD <- res_MAD$SAD
SSR_MAD <- compute_SSR(Xmat, Ymat, res_MAD$P)
comparison <- data.frame(
Method = c("RLS (Ch.3)", "ML/GLS (Ch.6,8)", "MAD (Ch.10)"),
SSR = c(SSR_RLS, SSR_ML, SSR_MAD),
SAD = c(compute_SAD(Xmat, Ymat, res_RLS$P),
compute_SAD(Xmat, Ymat, res_ML$P),
SAD_MAD),
Iterations = c(res_RLS$iterations, res_ML$outer_iterations, res_MAD$outer_iterations)
)
print(comparison, row.names = FALSE)
# =============================================================================
# COMPUTE P^k (Matrix Power)
# =============================================================================
compute_power_k <- function(P, k, crop_names, method_name) {
n <- nrow(P)
Res <- diag(n)
for (step in 1:k) {
Res <- Res %*% P
# Normalize rows to maintain stochastic property
Res <- Res / rowSums(Res)
}
rownames(Res) <- crop_names
colnames(Res) <- crop_names
cat(strrep("-", 60), "\n")
cat("P^", k, " (", method_name, " method)\n", sep = "")
cat(strrep("-", 60), "\n")
print(round(Res, 8))
cat("\nRow sums:", paste(round(rowSums(Res), 8), collapse = "  "), "\n\n")
invisible(Res)
}
cat("\n")
cat(strrep("=", 60), "\n")
cat("  P^k COMPUTATIONS (k = 2, 5, 10)\n")
cat(strrep("=", 60), "\n\n")
for (k in c(2, 5, 10)) {
cat(">>> k =", k, "\n\n")
compute_power_k(res_RLS$P, k, crop_names, "RLS")
compute_power_k(res_ML$P,  k, crop_names, "ML")
compute_power_k(res_MAD$P, k, crop_names, "MAD")
}
# =============================================================================
# STATIONARY (EQUILIBRIUM) DISTRIBUTION
#
# Book §1.1, eq.(1.1.10): pi = pi * P  with sum(pi) = 1
#
# Method: Solve (P' - I) * pi = 0 with the normalization sum(pi) = 1
# by replacing one equation with the sum constraint, then solving
# the resulting non-singular system via Gaussian elimination.
# (Equivalent to finding the left eigenvector for eigenvalue 1)
# =============================================================================
compute_stationary <- function(P, crop_names, method_name) {
n <- nrow(P)
# Set up system: (P' - I) * pi = 0
A <- t(P) - diag(n)
b <- rep(0, n)
# Replace last equation with sum(pi) = 1
A[n, ] <- rep(1, n)
b[n]   <- 1
# Solve
pi_vec <- solve(A, b)
# Ensure non-negativity and normalize
pi_vec <- pmax(pi_vec, 0)
pi_vec <- pi_vec / sum(pi_vec)
# Verification: pi * P should equal pi
piP <- as.numeric(pi_vec %*% P)
max_err <- max(abs(piP - pi_vec))
# Display
cat(strrep("-", 60), "\n")
cat("Stationary Distribution (", method_name, ")\n", sep = "")
cat(strrep("-", 60), "\n\n")
result_df <- data.frame(
Crop = crop_names,
`Stationary_pi` = round(pi_vec, 8),
`Verification_piP` = round(piP, 8),
Difference = formatC(abs(piP - pi_vec), digits = 12, format = "f")
)
print(result_df, row.names = FALSE)
cat("\nSum(pi)  :", round(sum(pi_vec), 8), "\n")
cat("Sum(pi*P):", round(sum(piP), 8), "\n")
cat("Max |pi*P - pi|:", formatC(max_err, digits = 15, format = "f"), "\n\n")
invisible(pi_vec)
}
cat("\n")
cat(strrep("=", 60), "\n")
cat("  STATIONARY (EQUILIBRIUM) DISTRIBUTIONS\n")
cat("  Book §1.1, eq.(1.1.10): pi = pi*P, sum(pi) = 1\n")
cat(strrep("=", 60), "\n\n")
pi_RLS <- compute_stationary(res_RLS$P, crop_names, "RLS")
pi_ML  <- compute_stationary(res_ML$P,  crop_names, "ML")
pi_MAD <- compute_stationary(res_MAD$P, crop_names, "MAD")
# Comparison of stationary distributions
cat(strrep("-", 60), "\n")
cat("Comparison of Equilibrium Proportions\n")
cat(strrep("-", 60), "\n\n")
eq_compare <- data.frame(
Crop = crop_names,
RLS = round(pi_RLS, 6),
ML  = round(pi_ML, 6),
MAD = round(pi_MAD, 6),
`Last_Observed` = round(S[nYears, ], 6)
)
print(eq_compare, row.names = FALSE)
cat("\nInterpretation: Long-run equilibrium crop area proportions\n")
cat("assuming constant transition probabilities.\n")
# =============================================================================
# ELEMENT-WISE COMPARISON OF THREE TPMs
# =============================================================================
cat("\n\n")
cat(strrep("=", 60), "\n")
cat("  ELEMENT-WISE DIFFERENCES BETWEEN METHODS\n")
cat(strrep("=", 60), "\n\n")
cat("Max |P_ML - P_RLS|  :", formatC(max(abs(res_ML$P - res_RLS$P)), digits = 8, format = "f"), "\n")
cat("Max |P_MAD - P_RLS| :", formatC(max(abs(res_MAD$P - res_RLS$P)), digits = 8, format = "f"), "\n")
cat("Max |P_MAD - P_ML|  :", formatC(max(abs(res_MAD$P - res_ML$P)), digits = 8, format = "f"), "\n\n")
cat("Frobenius norm |P_ML - P_RLS|  :", formatC(sqrt(sum((res_ML$P - res_RLS$P)^2)), digits = 8, format = "f"), "\n")
cat("Frobenius norm |P_MAD - P_RLS| :", formatC(sqrt(sum((res_MAD$P - res_RLS$P)^2)), digits = 8, format = "f"), "\n")
cat("Frobenius norm |P_MAD - P_ML|  :", formatC(sqrt(sum((res_MAD$P - res_ML$P)^2)), digits = 8, format = "f"), "\n")
cat("\n=== DONE ===\n")
library(tsDyn)
library(vars)
library(tseries)
library(forecast)
library(tidyverse)
library(stargazer)
library(urca)    # Required for ca.jo() and vec2var()
library(lmtest)
market_data <- read.csv(file.choose(), header=TRUE)
head(market_data)
agra <- ts(market_data$Agra)
beng <- ts(market_data$Bengaluru)
del  <- ts(market_data$Delhi)
mum  <- ts(market_data$Mumbai)
ahm  <- ts(market_data$Ahmedabad)
# Bind all together into a single dataframe/matrix for the models
ds_5 <- data.frame(agra, beng, del, mum, ahm)
autoplot(cbind(agra, beng, del, mum, ahm)) +
ggtitle("Market Prices Across 5 Cities") +
ylab("Price")
par(mfrow=c(3,2)) # Set up a grid for the plots
for(col_name in colnames(ds_5)) {
acf(ds_5[[col_name]], main=paste("ACF for", col_name))
}
par(mfrow=c(1,1))
par(mfrow=c(3,2)) # Set up a grid for the plots
for(col_name in colnames(ds_5)) {
pacf(ds_5[[col_name]], main=paste("ACF for", col_name))
}
par(mfrow=c(1,1))
lapply(ds_5, adf.test)
lapply(ds_5, function(x) adf.test(diff(x)))
lapply(ds_5, kpss.test)
lapply(ds_5, function(x) kpss.test(diff(x)))
lagselect <- VARselect(ds_5, lag.max=5, type="const")
print(lagselect$selection)
model_var_data <- VAR(ds_5, type="const", lag.max=2, ic="hq")
model_var_data <- VAR(ds_5, type="const", lag.max=2, ic="HQ")
summary(model_var_data)
stargazer(model_var_data[["varresult"]], type="text") # Can be very wide for 5 vars
# VAR model Prediction
pred_model_var_data <- predict(model_var_data, n.ahead=5)
plot(pred_model_var_data) # This will automatically plot all 5 forecasts
fanchart(pred_model_var_data)
# 1. Shock to Agra
irf_agra_shock <- irf(model_var_data, impulse = "agra",
response = c("beng", "del", "mum", "ahm"),
n.ahead = 10, boot = TRUE, run = 200, ci = 0.95)
plot(irf_agra_shock, main="Responses to Agra Shock")
# 2. Shock to Bengaluru
irf_beng_shock <- irf(model_var_data, impulse = "beng",
response = c("agra", "del", "mum", "ahm"),
n.ahead = 10, boot = TRUE, run = 200, ci = 0.95)
plot(irf_beng_shock, main="Responses to Bengaluru Shock")
# 3. Shock to Delhi (Your original code)
irf_del_shock <- irf(model_var_data, impulse = "del",
response = c("agra", "beng", "mum", "ahm"),
n.ahead = 10, boot = TRUE, run = 200, ci = 0.95)
plot(irf_del_shock, main="Responses to Delhi Shock")
# 4. Shock to Mumbai
irf_mum_shock <- irf(model_var_data, impulse = "mum",
response = c("agra", "beng", "del", "ahm"),
n.ahead = 10, boot = TRUE, run = 200, ci = 0.95)
plot(irf_mum_shock, main="Responses to Mumbai Shock")
# 5. Shock to Ahmedabad
irf_ahm_shock <- irf(model_var_data, impulse = "ahm",
response = c("agra", "beng", "del", "mum"),
n.ahead = 10, boot = TRUE, run = 200, ci = 0.95)
plot(irf_ahm_shock, main="Responses to Ahmedabad Shock")
# Forecast Error Variance Decomposition
vd_model_var_data <- fevd(model_var_data, n.ahead=6)
plot(vd_model_var_data)
# Diagnostic tests
serial_ds <- serial.test(model_var_data, lags.pt = 12, type = "PT.asymptotic")
print(serial_ds)
arch_ds <- arch.test(model_var_data, lags.multi = 12, multivariate.only = TRUE)
print(arch_ds)
stability_ds <- stability(model_var_data, type = "OLS-CUSUM")
plot(stability_ds)
########################################
# VECM Model Setup & Estimation
########################################
### Cointegration test (Johansen) ###
# K is the lag order (usually selected earlier minus 1).
cointest_trace <- ca.jo(ds_5, K=2, type="trace", ecdet="const", spec="longrun")
summary(cointest_trace)
cointest_eigen <- ca.jo(ds_5, K=2, type="eigen", ecdet="const", spec="longrun")
summary(cointest_eigen)
# VECM model Estimation
# IMPORTANT: 'r' must be set based on the results of the ca.jo summary above!
# For 5 variables, r can be anywhere from 0 to 4.
model_vecm_data <- VECM(ds_5, lag=2, r=1, estim="ML")
summary(model_vecm_data)
# VECM model Prediction
fcast_model_vecm_data <- predict(model_vecm_data, n.ahead = 6)
print(fcast_model_vecm_data)
########################################
# VECM Analysis & Engle-Granger
########################################
# Transform VECM to VAR for IRF and FEVD
# 'r' here must match the 'r' you used in VECM()
Model1VAR <- vec2var(cointest_trace, r = 1)
# Impulse Response from transformed model
vecm_irf <- irf(Model1VAR, impulse = "del", response = c("agra", "beng", "mum", "ahm"),
n.ahead = 20, boot = TRUE)
plot(vecm_irf, main = "VECM: Responses to Delhi Shock")
# Variance Decomposition
FEVD_vecm <- fevd(Model1VAR, n.ahead = 10)
plot(FEVD_vecm)
### Engle-Granger multi-step test for cointegration ###
# OLS Estimation (One variable against all others)
ols_eg <- lm(agra ~ beng + del + mum + ahm, data = ds_5)
summary(ols_eg)
# Test residuals for stationarity
residuals_eg <- resid(ols_eg)
adf.test(residuals_eg)
## The ARCH-M Variant{.scrollable}
setwd("C:/Quarto_projects/AECO605")
